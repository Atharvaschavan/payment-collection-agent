# Copy this file to .env and fill in your key. .env is git-ignored -- it
# will not be committed. Loaded automatically at startup (see
# payment_agent/config.py, which calls python-dotenv's load_dotenv()).

OPENAI_API_KEY=your-openai-api-key-here

